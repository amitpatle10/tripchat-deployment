# Copy this file to .env and fill in the values.
# .env is in .gitignore — never commit real secrets.

# ── PostgreSQL ────────────────────────────────────────────────────────────────
DB_NAME=tripchat
DB_USERNAME=tripchat
DB_PASSWORD=change_me_in_prod

# ── Redis ─────────────────────────────────────────────────────────────────────
# Leave empty to disable Redis auth (local dev only)
REDIS_PASSWORD=

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate a strong secret: openssl rand -hex 32
JWT_SECRET=replace_with_64_char_hex_string

# ── Spring Profile ────────────────────────────────────────────────────────────
SPRING_PROFILES_ACTIVE=default
